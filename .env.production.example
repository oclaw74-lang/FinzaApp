# =============================================================================
# Finza — Production environment variables template
# Copy to .env.production and fill in all values before deploying.
# NEVER commit .env.production — it is gitignored.
# =============================================================================

# --- Supabase (Settings > API in the Supabase dashboard) ---
SUPABASE_URL=https://omhfdzcrusahvvzoljpf.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# Supabase dashboard > Settings > API > JWT Secret
JWT_SECRET=

# --- Backend ---
ENVIRONMENT=production
# Replace with your actual domain (must match your certbot certificate)
CORS_ORIGINS=https://tu-dominio.com

# --- Frontend build args (embedded by Vite at build time) ---
VITE_SUPABASE_URL=https://omhfdzcrusahvvzoljpf.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=https://tu-dominio.com/api/v1

# --- Docker build targets (do not change for production) ---
BACKEND_TARGET=production
FRONTEND_TARGET=production
