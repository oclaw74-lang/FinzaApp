# ========================================
# FINZA — Variables de Producción
# ========================================
# Copiar a .env y llenar con valores reales
# NUNCA commitear el .env con valores reales

# --- Dominio ---
DOMAIN=finza.online
EMAIL=tu@email.com   # Para notificaciones de Let's Encrypt

# --- Supabase ---
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Base de datos (Supabase Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres
SYNC_DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# --- JWT (mismo secret que usa Supabase) ---
JWT_SECRET=tu-jwt-secret-de-supabase

# --- Build targets ---
BACKEND_TARGET=production
FRONTEND_TARGET=production

# --- App settings ---
ENVIRONMENT=production
CORS_ORIGINS=https://finza.online

# --- Frontend (baked into Vite build) ---
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=https://finza.online/api/v1
