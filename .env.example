# ================================================================
# Finza -- Variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA commitees el archivo .env con valores reales
# ================================================================

# --- Supabase (obtener desde: dashboard.supabase.com > Settings > API) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Database (PostgreSQL directo a Supabase) ---
# Obtener desde: Supabase > Settings > Database > Connection string
DATABASE_URL=postgresql+asyncpg://postgres:[TU-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:[TU-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# --- Auth ---
# Obtener desde: Supabase > Settings > API > JWT Secret
JWT_SECRET=tu-jwt-secret-de-supabase

# --- Backend ---
ENVIRONMENT=development
# ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info

# --- Frontend (prefijo VITE_ obligatorio para Vite) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_API_URL=http://localhost/api/v1

# --- Docker build targets ---
BACKEND_TARGET=development
FRONTEND_TARGET=development

# --- Web Push Notifications (VAPID) ---
# Generar con: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_key.to_pem().decode()); print('PUBLIC:', v.public_key.to_pem().decode())"
# O bien con la CLI: vapid --gen
# La clave privada se almacena como base64url (DER format)
VAPID_PRIVATE_KEY=tu-vapid-private-key-base64url
VAPID_PUBLIC_KEY=tu-vapid-public-key-base64url
# Email del administrador (requerido por el protocolo VAPID)
VAPID_EMAIL=admin@tudominio.com
